{
  "$schema": "https://schema.tauri.app/2.0.0/tauri.conf.json",
  "productName": "Hotel Designer Toolkit",
  "version": "1.0.1",
  "identifier": "com.hotel.designertoolkit",
  "build": {
    "beforeDevCommand": "npm run dev --prefix client",
    "beforeBuildCommand": "npm run build --prefix client",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "酒店牛马美工专用",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe"
    ]
  },
  "plugins": {
    "shell": {}
  }
}

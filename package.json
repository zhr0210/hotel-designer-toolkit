{
  "name": "hotel-designer-toolkit",
  "version": "1.0.0",
  "description": "酒店牛马美工专用",
  "main": "main.js",
  "scripts": {
    "postinstall": "cd client && npm install && cd ../server && npm install",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\" \"wait-on tcp:5173 && wait-on tcp:3001 && electron .\"",
    "start:client": "cd client && npm run dev",
    "start:server": "cd server && npm run dev",
    "build:client": "cd client && npm run build",
    "dist": "npm run build:client && electron-builder"
  },
  "build": {
    "appId": "com.hotel.designertoolkit",
    "productName": "酒店牛马美工专用",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "server/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  }
}
